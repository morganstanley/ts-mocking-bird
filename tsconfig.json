{
	"compilerOptions": {
		"target": "ES5",
		"module": "nodenext",
		"lib": ["ES5", "ES6", "DOM"],
		"declaration": true,
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": "./",
		"skipLibCheck": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"moduleResolution": "nodenext",
		"baseUrl": "./",
		"esModuleInterop": true
	},
	"exclude": ["dist"]
}